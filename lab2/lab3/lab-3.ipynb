    "def even_numbers(n):               #2.1\n",
    "    i=1\n",
    "    while i<=n:\n",
    "        if i%2==0:\n",
    "            if i%4==0:\n",
    "                yield 'кратно 4'\n",
    "            else:\n",
    "                yield i\n",
    "        i+=1\n",
    "for x in even_numbers(10):\n",
    "    print(x)"
   ],
