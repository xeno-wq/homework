    "def special_numbers(n):                   #4.1\n",
    "    i=1\n",
    "    a=True\n",
    "    while i<=n:\n",
    "        if i%3==0 and i%5==0:\n",
    "            yield 'FizzBuzz'\n",
    "        elif i%3==0:\n",
    "            yield 'Fizz'\n",
    "        elif i%5==0:\n",
    "            yield 'Buzz'\n",
    "        else:\n",
    "\n",
    "            for j in range(2,i):\n",
    "                if i%j==0 :\n",
    "                    a=False\n",
    "                    break\n",
    "            if a and i!=1:\n",
    "                yield 'простое'\n",
    "            else:\n",
    "                yield i\n",
    "\n",
    "        i+=1\n",
    "for x in special_numbers(15):\n",
    "    print(x)"
   ],
