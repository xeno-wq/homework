    "        elif i%5==0:\n",
    "            yield 'Buzz'\n",
    "        elif i%3==0:\n",
    "            yield 'Fizz'\n",
    "        else:\n",
    "            yield i\n",
    "        i+=1\n",
    "a=infinite_numbers()\n",
    "print(next(a))\n"
